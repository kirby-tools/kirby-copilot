{
  "name": "kirby-copilot",
  "type": "module",
  "version": "3.5.4",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "mprocs",
    "build": "kirbyup src/panel/index.ts",
    "build:assets": "rm -rf assets && tsdown --config src/assets/tsdown.config.ts",
    "build:playground": "PLAYGROUND=true pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"src/panel/**\" --write",
    "test": "vitest",
    "test:types": "tsc --noEmit",
    "release": "pnpm run build && pnpm run build:assets && bumpp --all --execute \"npx zx scripts/pre-release.mjs\" && zx scripts/post-release.mjs"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.19",
    "@antfu/eslint-config": "^7.7.0",
    "@kirby-tools/licensing": "^0.7.2",
    "@types/node": "^25.4.0",
    "ai": "^6.0.116",
    "autoprefixer": "^10.4.27",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "kirby-types": "^1.4.7",
    "kirbyup": "^3.4.1",
    "kirbyuse": "^1.3.0",
    "mprocs": "^0.8.3",
    "ohash": "^2.0.11",
    "pdfjs-dist": "^5.5.207",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.6",
    "tailwindcss": "^3.4.19",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3",
    "utilful": "^2.5.1",
    "vite": "~6.3.7",
    "vitest": "^4.0.18",
    "vue": "^2.7.16",
    "zod": "^4.3.6",
    "zx": "^8.8.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  }
}
