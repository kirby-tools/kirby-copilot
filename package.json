{
  "name": "kirby-copilot",
  "type": "module",
  "version": "3.8.1",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "mprocs",
    "build": "kirbyup src/panel/index.ts",
    "build:assets": "rm -rf assets && tsdown --config src/assets/tsdown.config.ts",
    "build:playground": "PLAYGROUND=true pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"src/panel/**\" --write",
    "test": "vitest",
    "test:types": "tsc --noEmit",
    "release": "pnpm run build && pnpm run build:assets && bumpp --all --execute \"npx zx scripts/pre-release.mjs\" && zx scripts/post-release.mjs"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.97",
    "@ai-sdk/google": "^3.0.94",
    "@ai-sdk/mistral": "^3.0.50",
    "@ai-sdk/openai": "^3.0.85",
    "@ai-sdk/provider": "^3.0.14",
    "@ai-sdk/provider-utils": "^4.0.39",
    "@antfu/eslint-config": "^9.1.0",
    "@kirby-tools/licensing": "^0.8.0",
    "@types/node": "^26.1.1",
    "@unocss/eslint-plugin": "^66.7.5",
    "ai": "^6.0.228",
    "bumpp": "^11.1.0",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "kirby-types": "^1.6.0",
    "kirbyup": "^3.4.1",
    "kirbyuse": "^1.3.1",
    "mprocs": "^0.9.6",
    "ohash": "^2.0.11",
    "pdfjs-dist": "^5.7.284",
    "prettier": "^3.9.5",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.11",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.42.1",
    "tsdown": "^0.22.8",
    "typescript": "^6.0.3",
    "unocss": "^66.7.5",
    "utilful": "^2.5.3",
    "vite": "~6.3.7",
    "vitest": "^4.1.10",
    "vue": "^2.7.16",
    "zod": "^4.4.3",
    "zx": "^8.8.5"
  }
}
